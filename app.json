{
  "expo": {
    "name": "不白刷",
    "slug": "video-bookmark-demo",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "videobookmarkdemo",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.playproject.videobookmarkdemo",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.playproject.videobookmarkdemo"
        ]
      },
      "infoPlist": {
        "AppGroup": "group.com.playproject.videobookmarkdemo",
        "LSApplicationQueriesSchemes": [
          "xhsdiscover",
          "snssdk1128",
          "bilibili",
          "kwai"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.playproject.videobookmarkdemo"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "./plugins/withShareExtension.js",
      "expo-font"
    ]
  }
}
